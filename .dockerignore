# The build needs: package manifests, server/, web/, android/ (APK build stage)
# and scripts/fetch-profile.sh (profiles stage). Everything else is excluded.
node_modules
npm-debug.log
.git
.gitignore
.dockerignore
Dockerfile
docker-compose.yml
test
docs
profiles
print-archive
result
flake.nix
flake.lock
*.md
*.log
.claude
.audit
# APK build outputs (built fresh in the image; keep local artifacts out)
android/.gradle
android/build
android/app/build
android/keystore.jks
